rules_version = '2';

// Firestore security rules for summit-app.
// Deploy via Firebase console or `firebase deploy --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Lightning Debates voting (existing) ───────────────────
    match /debates/{debateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /votes/{debateId}/userVotes/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    // ── Panel Q&A (new) ───────────────────────────────────────
    // Public read+write — submissions are anonymous and don't require Firebase Auth.
    // A client-generated device UUID (stored in localStorage as `summit_device_id`)
    // is written into `authorUid` for rate-limit / abuse-tracing and used as the
    // `upvoters/{uid}` doc ID so duplicate upvotes from the same device are blocked
    // by `create-only` semantics on that subcollection.
    match /panelQA/{sessionId}/questions/{qid} {
      allow read: if true;
      allow create: if
        request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 280
        && request.resource.data.authorUid is string
        && request.resource.data.authorUid.size() > 0
        && request.resource.data.authorUid.size() <= 64
        && request.resource.data.upvoteCount == 0;
      // Bumped only via transaction from the `upvoters/{uid}` create handler.
      // Accept only +1 increments to upvoteCount; reject any other field change.
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteCount'])
        && request.resource.data.upvoteCount == resource.data.upvoteCount + 1;
      allow delete: if false;
    }
    match /panelQA/{sessionId}/questions/{qid}/upvoters/{uid} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
